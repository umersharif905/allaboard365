# Optional: manual overrides instead of the interactive DB lookup in webhook-test.sh.
# Copy this file to defaults.env (same folder). webhook-test.sh sources defaults.env automatically.
#
# WEBHOOK_TEST_DB_NAME=allaboard-testing   # override DB for resolve-defaults.cjs only
# WEBHOOK_TEST_ENROLLMENT_SCOPE=group      # or individual — individual defaults to MightyWELL billing (ProductOwner / group tenant)
# WEBHOOK_TEST_INDIVIDUAL_BILLING_TENANT_ID=  # optional; default MightyWELL for ach-success-individual enrollment pick
# WEBHOOK_TEST_TEMPLATE_INVOICE_ID=        # set by resolve-defaults; ach_charge includes invoice_id for group invoice handler
# GROUP_SCHEDULE_ID=
# CUSTOMER_UUID=
# INDIVIDUAL_SCHEDULE_ID=
# ENROLLMENT_ID=
# WEBHOOK_TEST_GROUP_NAME=
# WEBHOOK_TEST_INDIVIDUAL_NAME=
# WEBHOOK_TEST_ENROLLMENT_MEMBER_NAME=
# WEBHOOK_TEST_INDIVIDUAL_PLAN_PREMIUM_AMOUNT=   # primary member plan total (individual recurring)
# WEBHOOK_TEST_ENROLLMENT_PREMIUM_AMOUNT=        # one-off ACH amount; omit to let resolve-defaults / merge fill (~17k with invoice template)
