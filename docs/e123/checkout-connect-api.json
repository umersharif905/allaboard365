{
  "openapi": "3.0.0",
  "info": {
    "title": "e123 Checkout Connect",
    "description": "Checkout Connect is designed to submit data and post it to the e123 enrollment system to create a checkout instance.",
    "version": "1"
  },
  "servers": [
    {
      "url": "https://enrollment123.com",
      "description": "Production Server"
    }
  ],
  "paths": {
