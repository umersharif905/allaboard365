{
  "name": "allaboard365-backend",
  "version": "1.0.0",
  "description": "Production backend API for AllAboard365 insurance platform",
  "main": "app.js",
  "scripts": {
    "prestart": "node scripts/ensure-shared.js",
    "start": "node app.js",
    "start:test": "node app.js",
    "dev": "cross-env NODE_ENV=development nodemon app.js",
    "dev:clean": "npx kill-port 3001 && cross-env NODE_ENV=development nodemon app.js",
    "prod:local": "node local-testing.js",
    "start:prod": "node app.js",
    "test": "jest",
    "test:enrollment": "jest services/__tests__/short-code.service.test.js routes/__tests__/enroll-now.shortcode.test.js routes/me/member/__tests__/email-verification.test.js services/__tests__/dimeService.decline.test.js services/__tests__/dimeService.ach.test.js services/__tests__/dimeService.matrix.test.js services/__tests__/paymentAttempt.service.test.js services/__tests__/enrollmentPaymentHoldService.test.js",
    "test:live": "jest -c jest.live.config.js",
    "test:watch": "jest --watch",
    "test:dime:integration": "node scripts/dime-integration-smoke.js",
    "test:e123:smoke": "node scripts/e123-smoke-test.js",
    "test:payment-failure-email": "node scripts/test-payment-failure-notifications.js",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "migrate": "node scripts/migrate.js",
    "seed:public-forms": "node scripts/seed-public-form-templates.js",
    "migrate:public-forms": "node scripts/run-public-forms-migration.js",
    "migrate:sql-file": "node scripts/run-sql-changes-file.js",
    "backfill:public-form-search": "node scripts/backfill-public-form-submission-search.js",
    "seed": "node scripts/seed.js",
    "build": "echo 'No build step required for Node.js'",
    "validate:deploy": "node scripts/ensure-shared.js && node scripts/validate-deploy.js --smoke",
    "deploy": "echo 'Deploy to Azure App Service'",
    "logs": "node scripts/logs.js"
  },
  "keywords": [
    "insurance",
    "enrollment",
    "api",
    "azure",
    "healthcare"
  ],
  "author": "AllAboard365",
  "license": "UNLICENSED",
