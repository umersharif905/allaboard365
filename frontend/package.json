{
  "name": "allaboard365-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Open-Enroll Frontend React + Vite application for Azure App Service",
  "engines": {
    "node": "22.x",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "postinstall": "cypress install",
    "cypress:install": "cypress install",
    "build:prod": "vite build --mode production --config vite.config.production.ts",
    "build:dev": "vite build --mode development --config vite.config.production.ts",
    "build": "tsc -p tsconfig.build.json && vite build --config vite.config.production.ts",
    "build:quick": "vite build --config vite.config.production.ts",
    "build:strict": "tsc && vite build --config vite.config.production.ts",
    "dev": "vite",
    "dev:test": "OE_TEST_SERVERS=1 OE_TEST_FRONTEND_PORT=5273 OE_TEST_BACKEND_PORT=3101 vite",
    "preview": "vite preview",
    "prod:serve": "npx serve -s dist -l 3000",
    "prod:local": "npm run build && npm run prod:serve",
    "start": "npm run prod:serve",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run src/__tests__/utils/basic.test.ts",
    "test:enrollment:unit": "vitest run src/services/__tests__/enrollment.service.test.ts src/components/__tests__/ShortCodeResolver.test.tsx src/pages/enrollment/__tests__/EnrollmentPage.test.tsx",
    "test:e2e": "cypress run --spec cypress/e2e/basic-functionality.cy.ts",
    "test:e2e:enrollment": "cypress run --spec \"cypress/e2e/enrollment/**/*.cy.ts\"",
    "test:e2e:headed": "cypress run --spec cypress/e2e/basic-functionality.cy.ts --headed --browser chrome",
    "test:e2e:open": "cypress open",
    "test:safe": "powershell ./run-safe-tests.ps1",
    "test:watch": "vitest --watch",
    "test:all": "npm run test:run && npm run test:coverage",
    "kill-3001": "lsof -ti:3001 | xargs kill -9 || true"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^5.1.1",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^7.2.0",
    "@mui/material": "^7.2.0",
    "@mui/system": "^7.2.0",
    "@mui/x-data-grid": "^8.7.0",
    "@mui/x-date-pickers": "^8.7.0",
    "@sendgrid/mail": "^8.1.5",
    "@sentry/react": "^10.49.0",
    "@tanstack/react-query": "^5.80.7",
    "@tanstack/react-query-devtools": "^5.80.7",
    "@usewaypoint/email-builder": "^0.0.9",
    "axios": "^1.10.0",
    "card-validator": "^8.1.1",
    "crypto": "^1.0.1",
    "date-fns": "^4.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.510.0",
    "multer": "^2.0.1",
    "papaparse": "^5.5.3",
    "pdfkit": "^0.17.1",
    "posthog-js": "^1.370.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.60.0",
    "react-hot-toast": "^2.5.2",
    "react-markdown": "^10.1.0",
    "react-pdf": "^9.1.0",
    "react-quill": "^2.0.0",
    "react-router-dom": "^7.6.2",
    "recharts": "^2.15.3",
    "serve": "^14.2.3",
    "twilio": "^5.10.7",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "yup": "^1.6.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.2.0",
    "@tailwindcss/forms": "^0.5.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/history": "^4.7.11",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.16.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/react-router-dom": "^5.3.3",
    "@types/recharts": "^1.8.29",
    "@types/stack-utils": "^2.0.3",
    "@types/yargs": "^17.0.33",
    "@types/yargs-parser": "^21.0.3",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "autoprefixer": "^10.4.21",
    "cypress": "^15.0.0",
    "eslint": "^9.30.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jsdom": "^23.2.0",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "tailwindcss": "^3.4.0",
    "terser": "^5.43.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^1.6.1"
  }
}
