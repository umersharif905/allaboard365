# Message Center Environment Variables
# Copy to .env and update with your values

# Azure Functions Runtime
AzureWebJobsStorage=UseDevelopmentStorage=true
FUNCTIONS_WORKER_RUNTIME=node

# Database Connection
DB_USER=oe-sqladmin
DB_PASSWORD=your_password_here
DB_SERVER=oe-sql-srvr.database.windows.net
DB_NAME=open-enroll

# SendGrid Configuration
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@allaboard365.com
SENDGRID_FROM_NAME=Open-Enroll

# Twilio Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15551234567

# Message Processing
MESSAGING_BATCH_SIZE=100
MESSAGING_RETRY_ATTEMPTS=5
MESSAGING_WORKER_INTERVAL_SECONDS=60

# Feature Flags
MESSAGING_EMAIL_ENABLED=true
MESSAGING_SMS_ENABLED=true
MESSAGING_PUSH_ENABLED=false