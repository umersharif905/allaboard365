# Dist
dist/

# Runtime config — generated per-environment (Azure App Service env vars in prod,
# .env / VITE_* fallback in local dev). Never commit; a committed copy overrides
# .env and forces local dev to talk to production. See frontend/src/config/api.ts.
frontend/public/config.json

# Deployment artifacts (produced by backend/deploy.sh, frontend/deploy.sh, etc.)
backend-deploy.zip
frontend-deploy.zip
*-deploy.zip
*_deployment.zip
*.deployment.zip

# Temporary/runtime files (exports, artifacts, scratch data)
backend/temp/

# Local DB export dumps
/exports/

# One-off AI scripts kept locally for reference (not tracked)
ai_scripts/one-offs/

# AI script output artifacts
ai_scripts/*.csv

# Temporary debug scripts
backend/check-*.js

# Backoffice / credentials knowledge base (SFTP, ShareWELL DB, Azure)
prompts/backoffice-master.md

